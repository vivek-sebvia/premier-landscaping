---
interface Props {
  title: string;
  image: string;
  primary?: string;
}

const { title, image, primary = '#8b2500' } = Astro.props;
---

<section class="page-hero">
  <div class="hero-overlay"></div>
  <img src={image} alt={title} class="hero-image" />
  <div class="hero-content">
    <div class="container">
      <h1 class="hero-title">{title}</h1>
      <div class="breadcrumbs">
        <a href="/">Home</a>
        <span class="sep">/</span>
        <span class="curr">{title}</span>
      </div>
    </div>
  </div>
</section>

<style define:vars={{ primary }}>
  .page-hero {
    position: relative;
    height: 360px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #1a1a1a;
  }
  .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.4));
    z-index: 2;
  }
  .hero-content {
    position: relative;
    z-index: 3;
    text-align: center;
    color: #fff;
    width: 100%;
  }
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .hero-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    margin-bottom: 1rem;
    text-transform: capitalize;
  }
  .breadcrumbs {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .breadcrumbs a {
    color: #eee;
    transition: color 0.2s;
  }
  .breadcrumbs a:hover {
    color: var(--primary);
  }
  .breadcrumbs .sep {
    color: #888;
  }
  .breadcrumbs .curr {
    color: var(--primary);
  }

  @media (max-width: 600px) {
    .page-hero { height: 280px; }
  }
</style>
