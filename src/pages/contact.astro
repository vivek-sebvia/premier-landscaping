---
import Layout from '../layouts/Layout.astro'
import { client } from '../client.config.js'
import PageHero from '../components/PageHero.astro'
const primary = client.primaryColor || '#8b2500'
---

<Layout title="Contact Us" description={`Contact ${client.name} for a free estimate. Serving ${client.city}, ${client.state}.`}>

  <PageHero 
    title="Get In Touch" 
    image="https://images.unsplash.com/photo-1598902108854-10e335adac99?w=1600&q=80" 
    primary={primary}
  />

  <section class="contact-page-section">
    <div class="container">
      <div class="contact-grid">
        
        <!-- Contact Info Side -->
        <div class="contact-info-col">
          <div class="info-header">
            <span class="sub-title">Contact Us</span>
            <h2 class="section-title">We're Ready to Help You <span>Grow</span></h2>
            <p class="info-desc">
              Whether you have a specific project in mind or just want to explore possibilities for your outdoor space, our team is here to provide expert guidance and a detailed, free estimate.
            </p>
          </div>

          <div class="info-cards">
            {client.phone && (
              <a href={`tel:${client.phone}`} class="info-card">
                <div class="icon-box">
                  <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div class="card-text">
                  <span>Call Us Anytime</span>
                  <h3>{client.phone}</h3>
                </div>
              </a>
            )}

            {client.email && (
              <a href={`mailto:${client.email}`} class="info-card">
                <div class="icon-box">
                  <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div class="card-text">
                  <span>Email Support</span>
                  <h3>{client.email}</h3>
                </div>
              </a>
            )}

            {client.address && (
              <div class="info-card">
                <div class="icon-box">
                  <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div class="card-text">
                  <span>Our Headquarters</span>
                  <h3>{client.address}, {client.city}</h3>
                </div>
              </div>
            )}
          </div>

          <div class="service-areas-box">
            <h4>Serving These Communities:</h4>
            <div class="areas-grid">
              {client.serviceArea?.map((area: string) => (
                <div class="area-tag">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                  {area}
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Form Side -->
        <div class="contact-form-col">
          <div class="form-wrapper">
            <div class="form-header">
              <h2>Request a Free Estimate</h2>
              <p>Fill out the form below and our landscape experts will contact you within 24 hours.</p>
            </div>
            
            <form id="contact-form" class="premium-form">
              <div class="form-row">
                <div class="form-group">
                  <label>First Name *</label>
                  <input type="text" name="firstName" placeholder="John" required />
                </div>
                <div class="form-group">
                  <label>Last Name *</label>
                  <input type="text" name="lastName" placeholder="Doe" required />
                </div>
              </div>
              
              <div class="form-row">
                <div class="form-group">
                  <label>Phone *</label>
                  <input type="tel" name="phone" placeholder="(555) 000-0000" required />
                </div>
                <div class="form-group">
                  <label>Email</label>
                  <input type="email" name="email" placeholder="john@example.com" />
                </div>
              </div>

              <div class="form-group">
                <label>Service Needed *</label>
                <div class="select-wrapper">
                  <select name="service" required>
                    <option value="">Select a service...</option>
                    {client.services.map((s: string) => <option value={s}>{s}</option>)}
                    <option value="other">Other</option>
                  </select>
                </div>
              </div>

              <div class="form-group">
                <label>Message</label>
                <textarea name="message" rows="4" placeholder="Tell us about your landscaping project, ideas, or questions..."></textarea>
              </div>

              <button type="submit" class="submit-btn">
                <span>Send Message</span>
                <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
              </button>
            </form>

            <div id="form-success" class="success-message">
              <div class="success-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              </div>
              <h3>Message Sent Successfully!</h3>
              <p>Thank you for reaching out. A landscaping specialist from {client.name} will contact you shortly to discuss your project.</p>
              <button onclick="location.reload()" class="btn-reset">Send Another Message</button>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Map Section / Trust Bar -->
  <section class="map-section">
    <div class="map-overlay">
      <div class="container">
        <div class="trust-content">
          <div class="trust-item">
            <span class="trust-num">100%</span>
            <span class="trust-label">Satisfaction Guaranteed</span>
          </div>
          <div class="trust-sep"></div>
          <div class="trust-item">
            <span class="trust-num">Free</span>
            <span class="trust-label">On-Site Estimates</span>
          </div>
          <div class="trust-sep"></div>
          <div class="trust-item">
            <span class="trust-num">24h</span>
            <span class="trust-label">Response Time</span>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style define:vars={{ primary }}>
  .contact-page-section {
    padding: 120px 0;
    background: var(--bg);
    position: relative;
    overflow: hidden;
  }

  .container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 80px;
    align-items: flex-start;
  }

  /* Info Column */
  .sub-title {
    display: block;
    color: var(--primary);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 14px;
    margin-bottom: 15px;
  }

  .section-title {
    font-size: 48px;
    font-weight: 800;
    color: var(--text);
    line-height: 1.1;
    margin-bottom: 25px;
  }

  .section-title span {
    color: var(--primary);
  }

  .info-desc {
    color: var(--text-muted);
    font-size: 18px;
    line-height: 1.8;
    margin-bottom: 45px;
    max-width: 500px;
  }

  .info-cards {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 50px;
  }

  .info-card {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 25px;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 20px;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .info-card:hover {
    transform: translateX(10px);
    border-color: var(--primary);
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }

  .icon-box {
    width: 60px;
    height: 60px;
    border-radius: 15px;
    background: var(--bg-secondary);
    color: var(--primary);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .info-card:hover .icon-box {
    background: var(--primary);
    color: #fff;
  }

  .card-text span {
    display: block;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 4px;
  }

  .card-text h3 {
    font-size: 20px;
    font-weight: 700;
    color: var(--text);
  }

  .service-areas-box {
    background: var(--bg-secondary);
    padding: 35px;
    border-radius: 24px;
    border: 1px solid var(--card-border);
  }

  .service-areas-box h4 {
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 20px;
  }

  .areas-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .area-tag {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 50px;
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
  }

  .area-tag svg {
    color: var(--primary);
  }

  /* Form Column */
  .form-wrapper {
    background: var(--card-bg);
    padding: 50px;
    border-radius: 32px;
    border: 1px solid var(--card-border);
    box-shadow: 0 30px 60px rgba(0,0,0,0.05);
  }

  .form-header {
    margin-bottom: 40px;
  }

  .form-header h2 {
    font-size: 28px;
    font-weight: 800;
    color: var(--text);
    margin-bottom: 12px;
  }

  .form-header p {
    color: var(--text-muted);
    font-size: 16px;
    line-height: 1.6;
  }

  .premium-form {
    display: flex;
    flex-direction: column;
    gap: 25px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .form-group label {
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 16px 20px;
    background: var(--bg-secondary);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    font-size: 16px;
    color: var(--text);
    outline: none;
    transition: all 0.3s ease;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--primary);
    background: var(--card-bg);
    box-shadow: 0 0 0 4px rgba(139, 37, 0, 0.1);
  }

  .select-wrapper {
    position: relative;
  }

  .select-wrapper::after {
    content: '▼';
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 12px;
    color: var(--text-muted);
    pointer-events: none;
  }

  select {
    appearance: none;
  }

  .submit-btn {
    margin-top: 15px;
    padding: 20px;
    background: var(--primary);
    color: #fff;
    border: none;
    border-radius: 12px;
    font-size: 17px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    transition: all 0.3s ease;
  }

  .submit-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(139, 37, 0, 0.2);
    filter: brightness(1.1);
  }

  /* Success Message */
  .success-message {
    display: none;
    text-align: center;
    padding: 20px 0;
  }

  .success-icon {
    width: 80px;
    height: 80px;
    background: #dcfce7;
    color: #16a34a;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 25px;
  }

  .success-message h3 {
    font-size: 24px;
    font-weight: 800;
    color: var(--text);
    margin-bottom: 15px;
  }

  .success-message p {
    color: var(--text-muted);
    font-size: 17px;
    line-height: 1.7;
    margin-bottom: 30px;
  }

  .btn-reset {
    background: none;
    border: 2px solid var(--primary);
    color: var(--primary);
    padding: 12px 30px;
    border-radius: 50px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn-reset:hover {
    background: var(--primary);
    color: #fff;
  }

  /* Map/Trust Section */
  .map-section {
    height: 200px;
    background-image: url('https://images.unsplash.com/photo-1590019158224-47c3ee736231?w=1600&q=80');
    background-size: cover;
    background-position: center;
    position: relative;
  }

  .map-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(rgba(15, 26, 15, 0.8), rgba(15, 26, 15, 0.9));
    display: flex;
    align-items: center;
  }

  .trust-content {
    display: flex;
    justify-content: space-around;
    align-items: center;
    color: #fff;
  }

  .trust-item {
    text-align: center;
  }

  .trust-num {
    display: block;
    font-size: 36px;
    font-weight: 800;
    color: var(--primary);
    margin-bottom: 5px;
  }

  .trust-label {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #aaa;
  }

  .trust-sep {
    width: 1px;
    height: 50px;
    background: rgba(255,255,255,0.1);
  }

  @media (max-width: 1024px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 60px;
    }
    .contact-info-col {
      order: 2;
    }
    .contact-form-col {
      order: 1;
    }
  }

  @media (max-width: 768px) {
    .contact-page-section { padding: 80px 0; }
    .form-wrapper { padding: 30px; }
    .form-row { grid-template-columns: 1fr; }
    .section-title { font-size: 36px; }
    .trust-content { flex-direction: column; gap: 40px; }
    .trust-sep { display: none; }
  }
</style>

<script>
  document.getElementById('contact-form')?.addEventListener('submit', (e) => {
    e.preventDefault()
    const form = document.getElementById('contact-form') as HTMLElement
    const success = document.getElementById('form-success') as HTMLElement
    form.style.display = 'none'
    success.style.display = 'block'
    
    // Smooth scroll to success message
    success.scrollIntoView({ behavior: 'smooth', block: 'center' });
  })
</script>