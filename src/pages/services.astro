---
import Layout from '../layouts/Layout.astro'
import { client } from '../client.config.js'
import PageHero from '../components/PageHero.astro'

let services = []
try {
  const res = await fetch(`${client.cmsUrl}/api/services?where[tenant.slug][equals]=${client.tenantSlug}&limit=50`)
  services = (await res.json()).docs || []
} catch {}

const displayServices = services.length
  ? services
  : client.services.map((s: string) => ({ 
      title: s, 
      description: `Expert ${s.toLowerCase()} services by licensed professionals in ${client.city}, ${client.state}.` 
    }))

const primary = client.primaryColor || '#2d5a3d'
---

<Layout title="Services" description={`Professional ${client.industry} services in ${client.city}, ${client.state}.`}>

  <PageHero 
    title="Our Services" 
    image="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1600&q=80" 
    primary={primary}
  />

  <!-- Services Grid Section -->
  <section class="services-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">WHAT WE OFFER</span>
        <h2 class="section-title">The services we offer to<br />our clients</h2>
        <p class="section-sub">
          Comprehensive {client.industry} services for homeowners and businesses in {client.city}.
        </p>
      </div>

      <div class="services-grid">
        {displayServices.map((service: any, i: number) => (
          <div class="service-card">
            <div class="service-card-top">
              <div class="service-icon-circle">
                <svg
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M12 22V12M12 12C12 7 7 3 2 4c0 5 4 9 10 8M12 12c0-5 5-9 10-8-1 5-5 8-10 8" />
                </svg>
              </div>
              <h3 class="service-title">{service.title}</h3>
              <p class="service-desc">{service.description}</p>
            </div>

            <div class="service-image-wrapper">
              <div class="service-mask-image">
                <img
                  src={`/services/${[
                    "lawn-care",
                    "garden-design",
                    "irrigation",
                    "tree-trimming",
                    "mulching",
                    "sod-installation",
                    "leaf-removal"
                  ][i % 7]}.png`}
                  alt={service.title}
                />
              </div>
              <a
                href={`/services/${service.slug || ''}`}
                class="service-arrow-btn"
                aria-label={`Read more about ${service.title}`}
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <line x1="7" y1="17" x2="17" y2="7" />
                  <polyline points="7 7 17 7 17 17" />
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-banner">
    <div class="container">
      <div class="cta-card">
        <h2 class="cta-title">Need a Service Not Listed?</h2>
        <p class="cta-sub">Contact us — we handle most {client.industry} needs in {client.city} and surrounding areas.</p>
        <div class="cta-btns">
          <a href="/contact" class="btn-cta-primary">GET A FREE QUOTE</a>
          <a href={`tel:${client.phone}`} class="btn-cta-outline">{client.phone}</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style set:html={`
  :root { --primary: ${primary}; }

  .container { max-width: 1280px; margin: 0 auto; padding: 0 1.5rem; }

  /* Section header */
  .section-header { text-align: center; margin-bottom: 4rem; }
  .section-tag {
    font-size: 0.75rem; font-weight: 700;
    letter-spacing: 0.12em; color: var(--primary);
    text-transform: uppercase; display: block;
    margin-bottom: 0.6rem;
  }
  .section-title { font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 800; color: var(--text); margin-bottom: 1rem; line-height: 1.1; }
  .section-sub { color: var(--text-muted); max-width: 600px; margin: 0 auto; line-height: 1.7; font-size: 1.05rem; }

  .services-section { padding: 8rem 0; background: var(--bg); }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2.5rem;
  }
  .service-card {
    background: var(--bg-secondary);
    border-radius: 24px 0 24px 0;
    display: flex;
    flex-direction: column;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    position: relative;
    border: 1px solid var(--card-border);
  }
  .service-card:hover { transform: translateY(-12px); box-shadow: 0 20px 40px rgba(0,0,0,0.08); }
  
  .service-card-top {
    padding: 3rem 2rem 1.5rem;
    text-align: center;
    flex: 1;
  }
  
  .service-icon-circle {
    width: 64px; height: 64px;
    border-radius: 50%;
    background: var(--primary);
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.75rem;
    box-shadow: 0 6px 15px color-mix(in srgb, var(--primary) 40%, transparent);
  }
  
  .service-title { font-weight: 800; font-size: 1.4rem; margin-bottom: 1rem; color: var(--text); }
  .service-desc { color: var(--text-muted); font-size: 0.95rem; line-height: 1.65; }
  
  .service-image-wrapper {
    position: relative;
    padding: 0 2rem 2.5rem;
    margin-top: 1rem;
  }
  
  .service-mask-image {
    width: 100%;
    aspect-ratio: 1.1;
    mask-image: url('/service-mask.svg');
    -webkit-mask-image: url('/service-mask.svg');
    mask-size: contain;
    -webkit-mask-size: contain;
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    mask-position: center;
    -webkit-mask-position: center;
    overflow: hidden;
  }
  
  .service-mask-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  
  .service-card:hover .service-mask-image img {
    transform: scale(1.12);
  }
  
  .service-arrow-btn {
    position: absolute;
    right: 2rem;
    bottom: 3rem;
    width: 50px; height: 50px;
    border-radius: 50%;
    background: var(--card-bg);
    color: var(--text);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 6px 20px rgba(0,0,0,0.1);
    transition: all 0.3s ease;
    z-index: 2;
    border: 1px solid var(--card-border);
  }
  
  .service-card:hover .service-arrow-btn {
    background: var(--primary);
    color: #fff;
    transform: rotate(45deg);
  }

  /* CTA Banner */
  .cta-banner { padding-bottom: 8rem; }
  .cta-card {
    background: #111;
    background: linear-gradient(135deg, #111 0%, #1a1a1a 100%);
    padding: 5rem 2rem;
    border-radius: 32px;
    text-align: center;
    color: #fff;
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .cta-card::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(circle at top right, var(--primary) 0%, transparent 40%);
    opacity: 0.15;
  }
  .cta-title { font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; margin-bottom: 1.25rem; position: relative; }
  .cta-sub { color: #aaa; font-size: 1.1rem; max-width: 600px; margin: 0 auto 2.5rem; position: relative; }
  .cta-btns { display: flex; gap: 1.25rem; justify-content: center; flex-wrap: wrap; position: relative; }
  
  .btn-cta-primary {
    background: var(--primary);
    color: #fff;
    padding: 1rem 2.5rem;
    border-radius: 12px;
    font-weight: 800;
    font-size: 0.95rem;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
  }
  .btn-cta-primary:hover { transform: translateY(-3px); box-shadow: 0 10px 20px color-mix(in srgb, var(--primary) 30%, transparent); }
  
  .btn-cta-outline {
    background: transparent;
    color: #fff;
    padding: 1rem 2.5rem;
    border-radius: 12px;
    font-weight: 800;
    font-size: 0.95rem;
    border: 2px solid rgba(255,255,255,0.2);
    transition: all 0.3s ease;
  }
  .btn-cta-outline:hover { border-color: #fff; background: rgba(255,255,255,0.05); }

  @media (max-width: 768px) {
    .services-section { padding: 5rem 0; }
    .cta-banner { padding-bottom: 5rem; }
    .cta-card { padding: 4rem 1.5rem; border-radius: 20px; }
  }
`}/>