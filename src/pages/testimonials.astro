---
import Layout from '../layouts/Layout.astro'
import { client } from '../client.config.js'
import PageHero from '../components/PageHero.astro'

const primary = client.primaryColor || '#8b2500'

const mockReviews = [
  {
    id: 1,
    name: "Sarah Montgomery",
    location: "Irvine, CA",
    rating: 5,
    date: "2 weeks ago",
    service: "Garden Design",
    text: "Absolutely thrilled with the transformation! Our backyard was a mess, but the team turned it into a sanctuary. The attention to detail in the plant selection and lighting was beyond what we expected.",
    avatar: "/reviews/avatar-2.png",
    verified: true
  },
  {
    id: 2,
    name: "David Richardson",
    location: "Irvine, CA",
    rating: 5,
    date: "1 month ago",
    service: "Lawn Maintenance",
    text: "The most reliable landscaping crew I've ever hired. Our lawn has never looked greener or more level. They show up on time every week and leave everything spotless. Highly recommend!",
    avatar: "/reviews/avatar-1.png",
    verified: true
  },
  {
    id: 3,
    name: "Michael Peterson",
    location: "Newport Beach, CA",
    rating: 5,
    date: "2 months ago",
    service: "Irrigation System",
    text: "Professional, clean, and efficient. They handled our smart irrigation installation in one day. Our water bill has actually gone down because the system is so efficient. Great investment.",
    initials: "MP",
    verified: true
  },
  {
    id: 4,
    name: "Jennifer Lopez",
    location: "Costa Mesa, CA",
    rating: 5,
    date: "3 months ago",
    service: "Commercial Maintenance",
    text: "We've been using Premier for our office park maintenance for over two years now. They are proactive and always alert us to potential issues before they become expensive problems.",
    initials: "JL",
    verified: true
  },
  {
    id: 5,
    name: "Robert Kennedy",
    location: "Irvine, CA",
    rating: 4,
    date: "4 months ago",
    service: "Hardscape & Patio",
    text: "Great communication throughout the whole patio renovation. The crew was respectful of our space and the final result is beautiful. Only 4 stars because the stone delivery was delayed, but the work itself is 5-star.",
    initials: "RK",
    verified: true
  },
  {
    id: 6,
    name: "Emily Watson",
    location: "Laguna Beach, CA",
    rating: 5,
    date: "5 months ago",
    service: "Sod Installation",
    text: "Immediate curb appeal boost! They prepped the soil perfectly and the new sod took root within days. Our neighbors keep asking who did the work. Thank you, Premier!",
    initials: "EW",
    verified: true
  }
]
---

<Layout title="Customer Reviews" description={`Read what our satisfied customers say about ${client.name} landscaping services in ${client.city}.`}>

  <PageHero 
    title="Customer Reviews" 
    image="/services/lawn-care.png" 
    primary={primary}
  />

  <section class="reviews-stats">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon" style={`color: ${primary}`}>⭐</div>
          <div class="stat-info">
            <span class="stat-value">4.9/5</span>
            <span class="stat-label">Average Rating</span>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon" style={`color: ${primary}`}>👥</div>
          <div class="stat-info">
            <span class="stat-value">250+</span>
            <span class="stat-label">Happy Clients</span>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon" style={`color: ${primary}`}>✅</div>
          <div class="stat-info">
            <span class="stat-value">100%</span>
            <span class="stat-label">Satisfaction Guarantee</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="reviews-section">
    <div class="container">
      <div class="reviews-grid">
        {mockReviews.map((review) => (
          <div class="review-card">
            <div class="review-header">
              <div class="user-info">
                {review.avatar ? (
                  <img src={review.avatar} alt={review.name} class="user-avatar" />
                ) : (
                  <div class="user-initials" style={`background: ${primary}20; color: ${primary}`}>
                    {review.initials}
                  </div>
                )}
                <div class="user-meta">
                  <h4>{review.name} {review.verified && <span class="verified-badge" title="Verified Customer">✓</span>}</h4>
                  <span class="location">{review.location}</span>
                </div>
              </div>
              <div class="review-rating">
                {[...Array(5)].map((_, i) => (
                  <span class="star" style={`color: ${i < review.rating ? '#ffb400' : '#ddd'}`}>★</span>
                ))}
              </div>
            </div>
            
            <div class="review-body">
              <div class="service-tag">{review.service}</div>
              <p>"{review.text}"</p>
            </div>

            <div class="review-footer">
              <span class="review-date">{review.date}</span>
              <div class="platform-icon">Google Review</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="submit-review-cta">
    <div class="container">
      <div class="cta-card">
        <div class="cta-text">
          <h2>Had a Great Experience?</h2>
          <p>We value your feedback. Let us know how we're doing!</p>
        </div>
        <a href="/contact" class="btn-primary" style={`background: ${primary}`}>Leave a Review</a>
      </div>
    </div>
  </section>

</Layout>

<style define:vars={{ primary }}>
  .reviews-stats {
    padding: 60px 0;
    background: var(--bg);
    border-bottom: 1px solid var(--card-border);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }

  .stat-card {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 20px;
  }

  .stat-icon {
    font-size: 32px;
    width: 60px;
    height: 60px;
    background: var(--bg-secondary);
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
  }

  .stat-info {
    display: flex;
    flex-direction: column;
  }

  .stat-value {
    font-size: 24px;
    font-weight: 800;
    color: var(--text);
  }

  .stat-label {
    font-size: 14px;
    color: var(--text-muted);
    font-weight: 500;
  }

  .reviews-section {
    padding: 100px 0;
    background: var(--bg-secondary);
  }

  .reviews-grid {
    column-count: 3;
    column-gap: 30px;
  }

  .review-card {
    break-inside: avoid;
    background: var(--card-bg);
    border-radius: 24px;
    padding: 30px;
    margin-bottom: 30px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.03);
    border: 1px solid var(--card-border);
    transition: transform 0.3s ease;
  }

  .review-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(0,0,0,0.06);
  }

  .review-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 25px;
  }

  .user-info {
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .user-avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    object-fit: cover;
  }

  .user-initials {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 18px;
  }

  .user-meta h4 {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .verified-badge {
    color: #3b82f6;
    font-size: 14px;
  }

  .location {
    font-size: 13px;
    color: var(--text-muted);
  }

  .star {
    font-size: 14px;
  }

  .review-body {
    margin-bottom: 25px;
  }

  .service-tag {
    display: inline-block;
    padding: 4px 12px;
    background: var(--bg-secondary);
    color: var(--text-muted);
    border-radius: 6px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .review-body p {
    font-size: 15px;
    line-height: 1.6;
    color: var(--text);
    font-style: italic;
  }

  .review-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 20px;
    border-top: 1px solid var(--card-border);
  }

  .review-date {
    font-size: 13px;
    color: var(--text-muted);
  }

  .platform-icon {
    font-size: 12px;
    color: var(--text-muted);
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .platform-icon::before {
    content: 'G';
    width: 18px;
    height: 18px;
    background: #ea4335;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    font-size: 10px;
  }

  .submit-review-cta {
    padding-bottom: 100px;
    background: var(--bg-secondary);
  }

  .cta-card {
    background: var(--card-bg);
    border-radius: 30px;
    padding: 50px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: 0 20px 50px rgba(0,0,0,0.05);
    border: 1px solid var(--card-border);
  }

  .cta-text h2 {
    font-size: 32px;
    font-weight: 800;
    margin-bottom: 10px;
    color: var(--text);
  }

  .cta-text p {
    color: var(--text-muted);
    font-size: 18px;
  }

  .btn-primary {
    color: #fff;
    padding: 18px 40px;
    border-radius: 15px;
    font-weight: 700;
    transition: transform 0.3s ease;
    text-decoration: none;
  }

  .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }

  @media (max-width: 1024px) {
    .reviews-grid {
      column-count: 2;
    }
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .cta-card {
      flex-direction: column;
      text-align: center;
      gap: 30px;
    }
  }

  @media (max-width: 640px) {
    .reviews-grid {
      column-count: 1;
    }
  }
</style>