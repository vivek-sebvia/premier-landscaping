---
import Layout from '../../layouts/Layout.astro'
import { client } from '../../client.config.js'
import PageHero from '../../components/PageHero.astro'

const primary = client.primaryColor || '#8b2500'

const mockPosts = [
  {
    id: 1,
    slug: "5-tips-for-a-greener-lawn",
    title: "5 Tips for a Greener Lawn This Spring",
    excerpt: "Learn the secrets to achieving a lush, vibrant green lawn that will be the envy of your neighborhood.",
    date: "April 15, 2026",
    category: "Lawn Care",
    image: "/services/lawn-care.png"
  },
  {
    id: 2,
    slug: "choosing-the-right-mulch",
    title: "Choosing the Right Mulch for Your Flower Beds",
    excerpt: "Not all mulch is created equal. Discover which type is best for your specific plants and soil conditions.",
    date: "April 10, 2026",
    category: "Design",
    image: "/services/mulching.png"
  },
  {
    id: 3,
    slug: "benefits-of-smart-irrigation",
    title: "The Benefits of Smart Irrigation Systems",
    excerpt: "Save water and money while keeping your garden perfectly hydrated with the latest smart technology.",
    date: "April 5, 2026",
    category: "Technology",
    image: "/services/irrigation.png"
  },
  {
    id: 4,
    slug: "ornamental-tree-pruning-guide",
    title: "Pruning Guide: When to Trim Your Ornamental Trees",
    excerpt: "Proper pruning is essential for tree health. Find out the best timing and techniques for your garden trees.",
    date: "March 28, 2026",
    category: "Maintenance",
    image: "/services/tree-trimming.png"
  }
]
---

<Layout title="Blog & Landscaping Tips" description={`Read the latest landscaping tips, trends, and news from ${client.name}.`}>

  <PageHero 
    title="Blog & Tips" 
    image="/gallery/project-1.png" 
    primary={primary}
  />

  <section class="blog-section">
    <div class="container">
      <div class="blog-header">
        <span class="sub-title">Resource Center</span>
        <h2 class="section-title">Latest <span>Insights</span></h2>
      </div>

      <div class="blog-grid">
        {mockPosts.map((post) => (
          <article class="blog-card">
            <div class="blog-img-wrapper">
              <img src={post.image} alt={post.title} loading="lazy" />
              <div class="category-badge">{post.category}</div>
            </div>
            <div class="blog-content">
              <div class="blog-meta">
                <span class="date">{post.date}</span>
                <span class="author">By {client.name} Team</span>
              </div>
              <h3><a href={`/blog/${post.slug}`}>{post.title}</a></h3>
              <p>{post.excerpt}</p>
              <a href={`/blog/${post.slug}`} class="read-more" style={`color: ${primary}`}>
                Read Article <span>→</span>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="newsletter-section">
    <div class="container">
      <div class="newsletter-card" style={`border-left: 5px solid ${primary}`}>
        <div class="newsletter-text">
          <h2>Subscribe to Our Newsletter</h2>
          <p>Get the latest landscaping tips and exclusive offers delivered to your inbox.</p>
        </div>
        <form class="newsletter-form">
          <input type="email" placeholder="Your email address" required />
          <button type="submit" style={`background: ${primary}`}>Subscribe</button>
        </form>
      </div>
    </div>
  </section>

</Layout>

<style define:vars={{ primary }}>
  .blog-hero {
    padding: 120px 0 80px;
    background: var(--bg);
    text-align: center;
  }

  .blog-section {
    padding: 100px 0;
    background: var(--bg);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .blog-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .sub-title {
    display: block;
    color: var(--primary);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 14px;
    margin-bottom: 15px;
  }

  .section-title {
    font-size: 42px;
    font-weight: 800;
    color: var(--text);
  }

  .section-title span {
    color: var(--primary);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px;
  }

  .blog-card {
    background: var(--card-bg);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.03);
    transition: all 0.3s ease;
    border: 1px solid var(--card-border);
  }

  .blog-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.08);
  }

  .blog-img-wrapper {
    position: relative;
    height: 280px;
    overflow: hidden;
  }

  .blog-img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .blog-card:hover .blog-img-wrapper img {
    transform: scale(1.05);
  }

  .category-badge {
    position: absolute;
    top: 20px;
    left: 20px;
    padding: 6px 16px;
    background: var(--card-bg);
    color: var(--text);
    border-radius: 50px;
    font-size: 12px;
    font-weight: 700;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    border: 1px solid var(--card-border);
  }

  .blog-content {
    padding: 35px;
  }

  .blog-meta {
    display: flex;
    gap: 20px;
    margin-bottom: 15px;
    font-size: 13px;
    color: var(--text-muted);
    font-weight: 500;
  }

  .blog-content h3 {
    font-size: 24px;
    font-weight: 800;
    margin-bottom: 15px;
    line-height: 1.3;
  }

  .blog-content h3 a {
    color: var(--text);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .blog-content h3 a:hover {
    color: var(--primary);
  }

  .blog-content p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 25px;
    font-size: 15px;
  }

  .read-more {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
    text-decoration: none;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .read-more span {
    transition: transform 0.3s ease;
  }

  .read-more:hover span {
    transform: translateX(5px);
  }

  /* Newsletter */
  .newsletter-section {
    padding-bottom: 100px;
    background: var(--bg-secondary);
  }

  .newsletter-card {
    background: var(--card-bg);
    padding: 50px;
    border-radius: 30px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.05);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 40px;
    border: 1px solid var(--card-border);
  }

  .newsletter-text h2 {
    font-size: 32px;
    font-weight: 800;
    margin-bottom: 10px;
    color: var(--text);
  }

  .newsletter-text p {
    color: var(--text-muted);
    font-size: 16px;
  }

  .newsletter-form {
    display: flex;
    gap: 15px;
    flex: 1;
    max-width: 500px;
  }

  .newsletter-form input {
    flex: 1;
    padding: 18px 25px;
    border-radius: 12px;
    border: 1px solid var(--card-border);
    background: var(--bg-secondary);
    color: var(--text);
    font-size: 15px;
    outline: none;
  }

  .newsletter-form button {
    padding: 18px 35px;
    background: var(--bg-secondary);
    color: var(--text-muted);
    font-weight: 700;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .newsletter-form button:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
  }

  @media (max-width: 1024px) {
    .blog-grid {
      gap: 30px;
    }
  }

  @media (max-width: 768px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
    .newsletter-card {
      flex-direction: column;
      text-align: center;
      padding: 40px 25px;
    }
    .newsletter-form {
      width: 100%;
    }
  }
</style>