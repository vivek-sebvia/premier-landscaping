---
import '../styles/global.css'
import { client } from '../client.config.js'
const { title, description } = Astro.props
const fullTitle = `${title} | ${client.name}`
const metaDesc = description || client.tagline
const currentPath = Astro.url.pathname
const primary = client.primaryColor || '#2d5a3d'
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script is:inline>
    const theme = (() => {
      if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
        return localStorage.getItem('theme');
      }
      if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        return 'dark';
      }
      return 'light';
    })();
  
    if (theme === 'light') {
      document.documentElement.setAttribute('data-theme', 'light');
    } else {
      document.documentElement.setAttribute('data-theme', 'dark');
    }
    window.localStorage.setItem('theme', theme);
  </script>
  <script is:inline src="https://unpkg.com/lenis@1.1.18/dist/lenis.min.js"></script>
  <title>{fullTitle}</title>
  <meta name="description" content={metaDesc} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style set:html={`
    :root {
      --primary: ${primary};
      --primary-dark: color-mix(in srgb, ${primary} 80%, #000);
      --primary-light: color-mix(in srgb, ${primary} 15%, #fff);
      --bg: #ffffff;
      --bg-secondary: #f8f9fa;
      --text: #1a1a1a;
      --text-muted: #666666;
      --card-bg: #ffffff;
      --card-border: rgba(0,0,0,0.05);
      --header-bg: #ffffff;
      --header-shadow: rgba(0,0,0,0.08);
      --footer-bg: #0f1a0f;
    }

    [data-theme="dark"] {
      --bg: #0a0e0a;
      --bg-secondary: #121812;
      --text: #f0f0f0;
      --text-muted: #aaaaaa;
      --card-bg: #161d16;
      --card-border: rgba(255,255,255,0.05);
      --header-bg: #0a0e0a;
      --header-shadow: rgba(0,0,0,0.3);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { transition: background-color 0.3s ease, color 0.3s ease; }
    body { font-family: 'Inter', system-ui, sans-serif; color: var(--text); background: var(--bg); transition: background-color 0.3s ease, color 0.3s ease; }
    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; height: auto; display: block; }

    /* Top Bar */
    .topbar {
      background: #111;
      color: #ccc;
      font-size: 0.78rem;
      padding: 0.45rem 1.5rem;
    }
    .topbar-inner {
      max-width: 1280px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .topbar-left { display: flex; gap: 1.5rem; align-items: center; }
    .topbar-left a { color: #ccc; transition: color 0.15s; }
    .topbar-left a:hover { color: ${primary}; }
    .topbar-right { display: flex; gap: 1.25rem; align-items: center; }
    .topbar-right a { color: #ccc; transition: color 0.15s; }
    .topbar-right a:hover { color: ${primary}; }
    .topbar-socials { display: flex; gap: 0.6rem; align-items: center; margin-left: 0.75rem; padding-left: 0.75rem; border-left: 1px solid #333; }
    .topbar-socials a {
      width: 26px; height: 26px;
      border: 1px solid #444; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      color: #ccc; font-size: 0.7rem; transition: all 0.15s;
    }
    .topbar-socials a:hover { background: ${primary}; border-color: ${primary}; color: #fff; }

    /* Main Header */
    .site-header {
      position: sticky; top: 0; z-index: 100;
      background: var(--header-bg);
      box-shadow: 0 2px 12px var(--header-shadow);
      transition: background-color 0.3s ease;
    }
    .header-inner {
      max-width: 1280px; margin: 0 auto;
      display: flex; align-items: center;
      justify-content: space-between;
      padding: 0 1.5rem;
      height: 72px;
    }
    .logo {
      display: flex; align-items: center; gap: 0.6rem;
      font-weight: 800; font-size: 1.3rem;
      color: #fff;
      background: ${primary};
      padding: 0.5rem 1.1rem;
      border-radius: 6px;
      letter-spacing: -0.02em;
    }
    .logo svg { flex-shrink: 0; }
    .main-nav { display: flex; align-items: center; gap: 0.25rem; }
    .nav-link {
      color: var(--text); font-weight: 500; font-size: 0.9rem;
      padding: 0.5rem 0.85rem; border-radius: 6px;
      transition: color 0.15s, background 0.15s;
      position: relative;
    }
    .nav-link:hover, .nav-link.active { color: ${primary}; background: color-mix(in srgb, ${primary} 8%, transparent); }
    
    .theme-toggle {
      background: var(--bg-secondary);
      border: 1px solid var(--card-border);
      color: var(--text);
      width: 40px; height: 40px;
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      margin-left: 1rem;
      transition: all 0.2s;
    }
    .theme-toggle:hover {
      background: var(--primary-light);
      color: var(--primary);
    }
    .theme-toggle .sun-icon { display: none; }
    [data-theme="dark"] .theme-toggle .moon-icon { display: none; }
    [data-theme="dark"] .theme-toggle .sun-icon { display: block; }

    .btn-quote {
      background: ${primary}; color: #fff;
      padding: 0.6rem 1.4rem; border-radius: 6px;
      font-weight: 700; font-size: 0.875rem;
      letter-spacing: 0.03em;
      transition: background 0.15s, transform 0.15s;
      margin-left: 0.5rem;
      border: 2px solid ${primary};
    }
    .btn-quote:hover { background: transparent; color: ${primary}; }

    /* Mobile menu */
    .menu-btn {
      display: none; background: none; border: none;
      cursor: pointer; padding: 0.4rem;
      color: var(--text);
    }
    #mobile-nav {
      display: none; flex-direction: column;
      padding: 1rem 1.5rem 1.25rem;
      background: var(--header-bg);
      border-top: 1px solid var(--card-border);
      gap: 0.15rem;
    }
    #mobile-nav a {
      color: var(--text); font-weight: 500;
      padding: 0.6rem 0.5rem;
      border-bottom: 1px solid var(--card-border);
      font-size: 0.95rem;
    }
    #mobile-nav a:last-child { border-bottom: none; }
    #mobile-nav .btn-quote { text-align: center; margin-top: 0.5rem; border-radius: 6px; }

    /* Footer */
    .site-footer {
      position: relative;
      background: #0f1a0f;
      color: #ccc;
      overflow: hidden;
    }
    .site-footer::before {
      content: '';
      position: absolute; inset: 0;
      background: url('https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1400&q=60') center/cover no-repeat;
      opacity: 0.12;
      pointer-events: none;
    }
    .footer-inner {
      position: relative; z-index: 1;
      max-width: 1280px; margin: 0 auto;
      padding: 4rem 1.5rem 2rem;
      display: grid;
      grid-template-columns: 1.4fr 1fr 1fr 1.2fr;
      gap: 3rem;
    }
    .footer-brand h3 {
      color: #fff; font-size: 1.5rem; font-weight: 800;
      margin-bottom: 0.4rem;
      display: flex; align-items: center; gap: 0.5rem;
    }
    .footer-brand p { font-size: 0.875rem; color: #aaa; line-height: 1.7; margin-bottom: 1.5rem; }
    .footer-newsletter label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; color: #fff; font-weight: 600; display: block; margin-bottom: 0.6rem; }
    .footer-newsletter-form { display: flex; gap: 0; }
    .footer-newsletter-form input {
      flex: 1; padding: 0.65rem 1rem;
      background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);
      border-right: none; border-radius: 6px 0 0 6px;
      color: #fff; font-size: 0.875rem; outline: none;
    }
    .footer-newsletter-form input::placeholder { color: #888; }
    .footer-newsletter-form button {
      background: ${primary}; color: #fff;
      border: none; padding: 0 1.1rem;
      border-radius: 0 6px 6px 0;
      font-weight: 700; font-size: 0.8rem;
      letter-spacing: 0.05em; cursor: pointer;
      transition: opacity 0.15s;
    }
    .footer-newsletter-form button:hover { opacity: 0.85; }
    .footer-col h4 { color: #fff; font-size: 1rem; font-weight: 700; margin-bottom: 1.25rem; }
    .footer-links { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
    .footer-links a { color: #aaa; font-size: 0.875rem; transition: color 0.15s; display: flex; align-items: center; gap: 0.5rem; }
    .footer-links a::before { content: '●'; color: ${primary}; font-size: 0.5rem; }
    .footer-links a:hover { color: ${primary}; }
    .footer-contact-item { display: flex; gap: 0.9rem; align-items: flex-start; margin-bottom: 1.1rem; }
    .footer-contact-icon {
      width: 38px; height: 38px; flex-shrink: 0;
      border: 2px solid ${primary}; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      color: ${primary}; font-size: 0.9rem;
    }
    .footer-contact-item p { font-size: 0.8rem; color: #888; margin-bottom: 0.1rem; }
    .footer-contact-item a, .footer-contact-item span { color: #ddd; font-size: 0.875rem; font-weight: 500; }
    .footer-contact-item a:hover { color: ${primary}; }
    .footer-bottom {
      position: relative; z-index: 1;
      border-top: 1px solid rgba(255,255,255,0.08);
      background: ${primary};
      padding: 1rem 1.5rem;
      display: flex; align-items: center; justify-content: space-between;
      gap: 1rem; flex-wrap: wrap;
    }
    .footer-bottom p { font-size: 0.8rem; color: rgba(255,255,255,0.85); }
    .footer-socials { display: flex; gap: 0.5rem; align-items: center; }
    .footer-socials span { font-size: 0.8rem; color: rgba(255,255,255,0.85); margin-right: 0.5rem; }
    .footer-socials a {
      width: 32px; height: 32px;
      background: rgba(255,255,255,0.15);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-size: 0.75rem;
      transition: background 0.15s;
    }
    .footer-socials a:hover { background: rgba(255,255,255,0.3); }

    /* Utilities */
    .desktop-only { display: flex; }
    .mobile-only { display: none; }
    @media (max-width: 900px) {
      .desktop-only { display: none !important; }
      .mobile-only { display: block !important; }
      .menu-btn { display: block; }
      .footer-inner { grid-template-columns: 1fr 1fr; gap: 2rem; }
    }
    @media (max-width: 600px) {
      .topbar-right .topbar-links { display: none; }
      .footer-inner { grid-template-columns: 1fr; gap: 1.75rem; }
      .footer-bottom { flex-direction: column; text-align: center; }
    }

    /* Lenis Smooth Scroll Styles */
    html.lenis,
    html.lenis body {
      height: auto;
    }
    .lenis.lenis-smooth {
      scroll-behavior: auto !important;
    }
    .lenis.lenis-smooth [data-lenis-prevent] {
      overscroll-behavior: contain;
    }
    .lenis.lenis-stopped {
      overflow: hidden;
    }
    .lenis.lenis-scrolling iframe {
      pointer-events: none;
    }
  `}></style>
</head>
<body>

  <!-- Top bar -->
  <div class="topbar">
    <div class="topbar-inner">
      <div class="topbar-left">
        <a href={`tel:${client.phone}`}>
          📞 {client.phone}
        </a>
        <a href={`mailto:${client.email}`}>
          ✉ {client.email}
        </a>
      </div>
      <div class="topbar-right">
        <span class="topbar-links" style="display:flex;gap:1.25rem;">
          <span>📍 {client.city}, {client.state}</span>
          <a href="/contact">Contact</a>
        </span>
        <div class="topbar-socials">
          <a href="#" aria-label="Facebook">f</a>
          <a href="#" aria-label="Twitter">𝕏</a>
          <a href="#" aria-label="Instagram">in</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Header -->
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22V12M12 12C12 7 7 3 2 4c0 5 4 9 10 8M12 12c0-5 5-9 10-8-1 5-5 8-10 8"/>
        </svg>
        {client.name}
      </a>

      <nav class="main-nav desktop-only">
        <a href="/" class={`nav-link${currentPath==='/'?' active':''}`}>Home</a>
        <a href="/services" class={`nav-link${currentPath==='/services'?' active':''}`}>Services</a>
        <a href="/about" class={`nav-link${currentPath==='/about'?' active':''}`}>About</a>
        <a href="/gallery" class={`nav-link${currentPath==='/gallery'?' active':''}`}>Gallery</a>
        <a href="/testimonials" class={`nav-link${currentPath==='/testimonials'?' active':''}`}>Reviews</a>
        <a href="/blog" class={`nav-link${currentPath==='/blog'?' active':''}`}>Blog</a>
        <a href="/contact" class={`nav-link${currentPath==='/contact'?' active':''}`}>Contact</a>
        
        <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode">
          <svg class="moon-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
          <svg class="sun-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
        </button>

        <a href="/contact" class="btn-quote">GET A QUOTE</a>
      </nav>

      <button id="menu-btn" class="menu-btn mobile-only" aria-label="Toggle menu">
        <svg width="26" height="26" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>

    <div id="mobile-nav">
      <a href="/">Home</a>
      <a href="/services">Services</a>
      <a href="/about">About</a>
      <a href="/gallery">Gallery</a>
      <a href="/testimonials">Reviews</a>
      <a href="/blog">Blog</a>
      <a href="/contact">Contact</a>
      <a href="/contact" class="btn-quote">GET A QUOTE</a>
    </div>
  </header>

  <main style="flex:1"><slot /></main>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-inner">
      <!-- Brand -->
      <div class="footer-brand">
        <h3>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style={`color:${primary}`}>
            <path d="M12 22V12M12 12C12 7 7 3 2 4c0 5 4 9 10 8M12 12c0-5 5-9 10-8-1 5-5 8-10 8"/>
          </svg>
          {client.name}
        </h3>
        <p>Trusted by homeowners in {client.city} for professional {client.industry} services. Licensed, insured, and dedicated to quality.</p>
        <div class="footer-newsletter">
          <label>Newsletter</label>
          <div class="footer-newsletter-form">
            <input type="email" placeholder="Email Address" />
            <button type="button">SUBMIT</button>
          </div>
        </div>
      </div>

      <!-- Links -->
      <div class="footer-col">
        <h4>Quick Links</h4>
        <ul class="footer-links">
          <li><a href="/">Home</a></li>
          <li><a href="/services">Services</a></li>
          <li><a href="/about">About Us</a></li>
          <li><a href="/gallery">Gallery</a></li>
          <li><a href="/contact">Contact Us</a></li>
        </ul>
      </div>

      <!-- Services -->
      <div class="footer-col">
        <h4>Our Services</h4>
        <ul class="footer-links">
          {client.services.slice(0,5).map((s: string) => (
            <li><a href="/services">{s}</a></li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer-col">
        <h4>Find Us</h4>
        {client.address && (
          <div class="footer-contact-item">
            <div class="footer-contact-icon">📍</div>
            <div>
              <p>Address</p>
              <span>{client.address}, {client.city}, {client.state}</span>
            </div>
          </div>
        )}
        {client.phone && (
          <div class="footer-contact-item">
            <div class="footer-contact-icon">📞</div>
            <div>
              <p>Get In Touch</p>
              <a href={`tel:${client.phone}`}>{client.phone}</a>
            </div>
          </div>
        )}
        {client.email && (
          <div class="footer-contact-item">
            <div class="footer-contact-icon">✉</div>
            <div>
              <p>Quick Email Us</p>
              <a href={`mailto:${client.email}`}>{client.email}</a>
            </div>
          </div>
        )}
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p>© {new Date().getFullYear()} {client.name}. All Rights Reserved.</p>
      <div class="footer-socials">
        <span>Social</span>
        <a href="#" aria-label="Facebook">f</a>
        <a href="#" aria-label="Twitter">𝕏</a>
        <a href="#" aria-label="Pinterest">P</a>
        <a href="#" aria-label="Instagram">in</a>
      </div>
    </div>
  </footer>

  <script>
    const btn = document.getElementById('menu-btn');
    const nav = document.getElementById('mobile-nav');
    btn?.addEventListener('click', () => {
      if (!nav) return;
      nav.style.display = nav.style.display === 'flex' ? 'none' : 'flex';
    });

    // Theme toggle
    const handleToggleClick = () => {
      const element = document.documentElement;
      const isDark = element.getAttribute('data-theme') === 'dark';
      const nextTheme = isDark ? 'light' : 'dark';
      
      element.setAttribute('data-theme', nextTheme);
      localStorage.setItem("theme", nextTheme);
    }
  
    document.getElementById("theme-toggle")?.addEventListener("click", handleToggleClick);

    // Lenis Smooth Scroll Integration (CDN)
    const lenis = new (window as any).Lenis({
      duration: 1.2,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smoothWheel: true,
      wheelMultiplier: 1,
      touchMultiplier: 2,
      infinite: false,
    })

    function raf(time: number) {
      lenis.raf(time)
      requestAnimationFrame(raf)
    }

    requestAnimationFrame(raf)

    // Handle internal links for Lenis
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (this: HTMLAnchorElement, e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href')!);
        if (target instanceof HTMLElement) {
          lenis.scrollTo(target);
        }
      });
    });
  </script>
</body>
</html>
